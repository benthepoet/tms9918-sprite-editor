{
  "version": 1,
  "name": "Generic DB",
  "description": "db $XX directives for Z80/6502-style assemblers",
  "dialect": {
    "comment_prefix": ";",
    "data_directive": "db",
    "hex_prefix": "$",
    "hex_uppercase": true,
    "hex_width": 2,
    "value_separator": ",",
    "bytes_per_line": 8,
    "indent": "    "
  },
  "labels": {
    "case": "upper",
    "max_length": 32,
    "patterns": {
      "animation": "{anim_name}",
      "frame": "{anim_label}_F{frame_index:02d}",
      "sprite": "{frame_label}_S{slot:02d}",
      "duration_table": "{anim_label}_DUR",
      "frame_count": "{anim_label}_NFRAMES"
    }
  },
  "animation": {
    "sections": {
      "header": {
        "enabled": true,
        "lines": [
          "{comment} animation {anim_name}",
          "{comment} frames {frame_count}"
        ]
      },
      "frames": {
        "enabled": true,
        "per_frame": {
          "enabled": true,
          "label": { "enabled": true, "template": "{frame_label}" },
          "lines": [
            "{comment} duration {duration}"
          ]
        },
        "per_sprite": {
          "enabled": true,
          "label": { "enabled": false, "template": "{sprite_label}" },
          "comment": {
            "enabled": true,
            "template": "{comment} sprite {slot:02d} color {color}"
          },
          "data": {
            "enabled": true,
            "bytes_per_line": 8,
            "template": "{indent}{data_line}"
          }
        }
      },
      "duration_table": {
        "enabled": true,
        "label": { "enabled": true, "template": "{duration_table_label}" },
        "comment": {
          "enabled": true,
          "template": "{comment} frame durations"
        },
        "data": {
          "enabled": true,
          "bytes_per_line": 16,
          "template": "{indent}{duration_line}"
        }
      },
      "frame_count": {
        "enabled": false,
        "label": { "enabled": true, "template": "{frame_count_label}" },
        "comment": { "enabled": false, "template": "" },
        "data": { "enabled": true, "template": "{indent}{data_directive} {frame_count}" }
      },
      "footer": {
        "enabled": true,
        "lines": [
          "{comment} total duration {total_duration} frames"
        ]
      }
    }
  },
  "sprite": {
    "sections": {
      "label": { "enabled": false, "template": "{sprite_label}" },
      "comment": {
        "enabled": true,
        "template": "{comment} sprite {slot:02d} color {color}"
      },
      "data": {
        "enabled": true,
        "bytes_per_line": 8,
        "template": "{indent}{data_line}"
      }
    }
  }
}