{
  "version": 1,
  "name": "TI-99/4A Default",
  "description": "TI-99 BYTE export with SPR labels, frame labels, and a duration data table",
  "dialect": {
    "comment_prefix": ";",
    "data_directive": "BYTE",
    "hex_prefix": ">",
    "hex_uppercase": true,
    "hex_width": 2,
    "value_separator": ",",
    "bytes_per_line": 8,
    "indent": "    "
  },
  "labels": {
    "case": "upper",
    "max_length": 32,
    "patterns": {
      "animation": "{anim_name}",
      "frame": "{anim_label}_F{frame_index:02d}",
      "sprite": "{sprite_name}",
      "duration_table": "{anim_label}_DUR",
      "frame_count": "{anim_label}_NFRAMES"
    }
  },
  "animation": {
    "sections": {
      "header": {
        "enabled": true,
        "lines": [
          "{comment} Animation: {anim_name}",
          "{comment} Frames: {frame_count}"
        ]
      },
      "frames": {
        "enabled": true,
        "per_frame": {
          "enabled": true,
          "label": { "enabled": true, "template": "{frame_label}" },
          "lines": [
            "{comment} Duration: {duration} screen frames"
          ]
        },
        "per_sprite": {
          "enabled": true,
          "label": { "enabled": true, "template": "{sprite_label}", "colon": false },
          "comment": {
            "enabled": true,
            "template": "{comment} Sprite {slot:02d} {size}x{size} Color {color}"
          },
          "data": {
            "enabled": true,
            "bytes_per_line": 8,
            "template": "{indent}{data_line}"
          }
        }
      },
      "duration_table": {
        "enabled": true,
        "label": { "enabled": true, "template": "{duration_table_label}" },
        "comment": {
          "enabled": true,
          "template": "{comment} Frame durations (screen frames)"
        },
        "data": {
          "enabled": true,
          "bytes_per_line": 16,
          "template": "{indent}{duration_line}"
        }
      },
      "frame_count": {
        "enabled": false,
        "label": { "enabled": true, "template": "{frame_count_label}" },
        "comment": { "enabled": true, "template": "{comment} Frame count" },
        "data": { "enabled": true, "template": "{indent}{data_directive} {frame_count}" }
      },
      "footer": {
        "enabled": true,
        "lines": [
          "{comment} Total cycle: {total_duration} screen frames (~{total_ms} ms)"
        ]
      }
    }
  },
  "sprite": {
    "sections": {
      "label": { "enabled": true, "template": "{sprite_label}", "colon": false },
      "comment": {
        "enabled": true,
        "template": "{comment} Sprite {slot:02d} {size}x{size} Color {color}"
      },
      "data": {
        "enabled": true,
        "bytes_per_line": 8,
        "template": "{indent}{data_line}"
      }
    }
  }
}